{
  "name": "optica",
  "description": "Responsively scaling CSS properties for JavaScript.",
  "version": "0.0.0-development",
  "repository": "github:tobua/optica",
  "license": "MIT",
  "author": "Matthias Giger",
  "scripts": {
    "check": "biome check --write .",
    "types": "tsc"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "typescript": "^6.0.2",
    "zero-configuration": "^1.1.1"
  },
  "trustedDependencies": [
    "zero-configuration"
  ],
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "*.ts"
  ],
  "keywords": [
    "css",
    "responsive",
    "fluid",
    "scale",
    "typescript"
  ],
  "publishConfig": {
    "provenance": true
  },
  "configuration": {
    "gitignore": "recommended",
    "vscode": "biome",
    "biome": [
      {
        "extends": "recommended",
        "linter": {
          "rules": {
            "style": {
              "useBlockStatements": "off"
            }
          }
        },
        "files": {
          "includes": [
            "**/*",
            "!test/**"
          ]
        }
      },
      {
        "folder": "test",
        "extends": "test",
        "root": false
      }
    ],
    "typescript": [
      {
        "extends": "plugin",
        "compilerOptions": {
          "types": [
            "bun"
          ]
        },
        "include": [
          "index.ts",
          "test/*.test.ts"
        ]
      }
    ]
  }
}
